# Copy to .env and fill in. Settings (backend/app/core/config.py) reads these
# case-insensitively via pydantic-settings — LLM_PROVIDER or llm_provider,
# either works.

# Which LLM provider backs the conversational agent: claude_cli | gemini | anthropic
#
#   claude_cli  - shells out to the `claude` CLI. Only works where that CLI
#                 is installed and authenticated (dev machines) — NOT a valid
#                 choice for a deployed container. This is the local default.
#   gemini      - Google Gemini API. The deployed/Render default — set
#                 GEMINI_API_KEY below.
#   anthropic   - Anthropic API directly. Set ANTHROPIC_API_KEY below.
#
# An unset key for whichever provider is active makes the app fail to start,
# with a clear error — by design, so a misconfigured deploy fails loudly
# instead of silently falling back to a broken provider.
LLM_PROVIDER=claude_cli

# Required if LLM_PROVIDER=gemini
GEMINI_API_KEY=

# Required if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Port the app listens on. Render (and most PaaS hosts) set $PORT themselves
# at runtime — leave this unset in production; it's here for local overrides.
PORT=8000
